<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<oddjob id="oddjob">
    <job>
        <sequential>
            <jobs>
                <properties>
                    <values>
                        <value key="example.server.port" value="8080"/>
                        <value key="example.server.host" value="localhost"/>
                    </values>
                </properties>
                <bus:bus xmlns:bus="oddjob:beanbus">
                    <of>
                        <vertx:http-client xmlns:vertx="oddjob:vertx">
                            <url>
                                <value value="http://${example.server.host}:${example.server.port}/data"/>
                            </url>
                            <dataInHow>
                                <dido:json xmlns:dido="oddjob:dido">
                                    <schema>
                                        <import file="${oddjob.dir}/FruitSchema.xml"/>
                                    </schema>
                                </dido:json>
                            </dataInHow>
                        </vertx:http-client>
                        <bus:collect id="data"/>
                    </of>
                </bus:bus>
            </jobs>
        </sequential>
    </job>
</oddjob>
