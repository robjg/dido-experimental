<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<oddjob id="oddjob">
    <job>
        <cascade>
            <jobs>
                <properties>
                    <values>
                        <value key="example.server.port" value="8080"/>
                    </values>
                </properties>
                <oddjob id="dido" file="${oddjob.dir}/CsvDidoPipe.xml"/>
                <vertx:http-server id="server" xmlns:vertx="oddjob:vertx" port="${example.server.port}">
                    <endpoints>
                        <is key="/data" mediaType="application/json">
                            <how>
                                <dido:json xmlns:dido="oddjob:dido"/>
                            </how>
                            <data>
                                <value value="${dido/data.list}"/>
                            </data>
                        </is>
                    </endpoints>
                </vertx:http-server>
            </jobs>
        </cascade>
    </job>
</oddjob>
